# ──────────────────────────────────────────────
# Portfolio Backend — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# Alternatively, create backend/src/config/develop.json
# (see backend/src/config/develop.example.json for the shape).
#
# The backend checks env vars first; if unset it falls
# back to the JSON config file for the current NODE_ENV.
# ──────────────────────────────────────────────

NODE_ENV=develop

# ── Server ────────────────────────────────────
PORT=3000
NAME="Personal Website Backend"
MODE=Development
PROTOCOL=http
SERVER_URL=http://localhost:3000
SERVER_URL_WEB_URL_LINK=http://localhost:3000
FRONTEND_URL_WEB_URL_LINK=http://localhost:5173

# ── MongoDB Atlas ─────────────────────────────
MONGO_HOST=cluster0.xxxxx.mongodb.net
MONGO_PORT=
MONGO_USER=your_mongo_user
MONGO_PASSWORD=your_mongo_password
MONGO_DATABASE=your_database_name
MONGO_ADDITIONAL_PARAMETERS=retryWrites=true&w=majority

# ── Admin Panel ───────────────────────────────
# Password must be a bcrypt hash (generate with: npx bcrypt-cli 'your_password' 10)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=$2b$10$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── JWT ───────────────────────────────────────
JWT_SECRET=change-me-to-a-random-secret

# ── Notification Email (Hotmail/Outlook) ──────
NOTIFY_EMAIL_SERVICE=hotmail
NOTIFY_EMAIL=your_email@hotmail.com
NOTIFY_EMAIL_PASSWORD=your_email_password

# ── Contact Form Recipient ────────────────────
CONTACT_EMAIL=your_contact@gmail.com

# ── Private Email (optional) ──────────────────
PRIVATE_EMAIL_ENABLED=false
PRIVATE_EMAIL_HOST=mail.privateemail.com
PRIVATE_EMAIL_PORT=465
PRIVATE_EMAIL_USER=contact@yourdomain.com
PRIVATE_EMAIL_PASSWORD=your_private_email_password
PRIVATE_EMAIL_SECURE=true
